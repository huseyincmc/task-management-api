# Required by Docker Compose and the docker Spring profile.
POSTGRES_USER=your_dev_username
POSTGRES_PASSWORD=your_dev_password
POSTGRES_DB=taskdb
NOTIFICATION_POSTGRES_DB=notificationdb

# Spring profile selection is set by docker-compose for containers.
# Local IntelliJ runs use the default local profile unless overridden.

# Optional notification client resilience settings.
NOTIFICATION_SERVICE_RETRY_MAX_ATTEMPTS=2
NOTIFICATION_SERVICE_RETRY_DELAY_MILLIS=500
NOTIFICATION_SERVICE_CIRCUIT_BREAKER_FAILURE_RATE_THRESHOLD=50
NOTIFICATION_SERVICE_CIRCUIT_BREAKER_MINIMUM_NUMBER_OF_CALLS=4
NOTIFICATION_SERVICE_CIRCUIT_BREAKER_SLIDING_WINDOW_SIZE=4
NOTIFICATION_SERVICE_CIRCUIT_BREAKER_WAIT_DURATION_IN_OPEN_STATE=10s
NOTIFICATION_SERVICE_CIRCUIT_BREAKER_HALF_OPEN_CALLS=2

NOTIFICATION_SERVICE_RATE_LIMIT_FOR_PERIOD=3
NOTIFICATION_SERVICE_RATE_LIMIT_REFRESH_PERIOD=10s
NOTIFICATION_SERVICE_RATE_LIMIT_TIMEOUT_DURATION=0s
